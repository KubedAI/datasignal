---
const expertise = [
  { title: "Data & AI on Kubernetes", desc: "Running Spark, Flink, Trino, StarRocks and ML workloads natively on EKS — from scheduling to cost to reliability.", color: "#E25A1C" },
  { title: "Distributed Compute", desc: "Petabyte-scale Spark pipelines, shuffle optimization, YuniKorn gang scheduling, Karpenter node provisioning.", color: "#00C9FF" },
  { title: "Stream Processing", desc: "Flink stateful pipelines, RocksDB backends, incremental checkpointing, Kafka-native ingestion at scale.", color: "#C751EE" },
  { title: "Federated Query Engines", desc: "Trino federation across S3, Iceberg, and RDBMS. Multi-tenant isolation, Alluxio caching, Spot-safe workers.", color: "#F5C400" },
  { title: "Lakehouse Engineering", desc: "StarRocks shared-data mode, Delta Lake and Apache Iceberg on S3, sub-second analytics at warehouse scale.", color: "#4ADE80" },
  { title: "Platform Cost Engineering", desc: "Spot strategy, right-sizing, Karpenter bin-packing, Celeborn external shuffle — saving real dollars at real scale.", color: "#F87171" },
];


const connect = [
  {
    href: "https://www.linkedin.com/in/varaprofile/",
    label: "LinkedIn",
    handle: "linkedin.com/in/varaprofile",
    color: "#0A66C2",
    svgPath: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vara Bonthu — Data Signal</title>
    <meta name="description" content="Vara Bonthu — Data and AI on Kubernetes. Principal Solutions Architect at AWS, specializing in open-source data frameworks on EKS." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body {
        background: #050810;
        color: #F0F4FF;
        font-family: 'Space Grotesk', sans-serif;
        min-height: 100%;
      }
      ::-webkit-scrollbar { width: 4px; background: transparent; }
      ::-webkit-scrollbar-thumb { background: #1A2540; border-radius: 2px; }
      a { font-family: 'Space Grotesk', sans-serif; }

      .expertise-card {
        padding: 18px 20px;
        border-radius: 12px;
        background: #0A0F1E;
        border: 1px solid #1A2540;
        transition: border-color 0.2s, transform 0.2s;
      }
      .expertise-card:hover {
        transform: translateY(-2px);
        border-color: #2A3A56;
      }
      .connect-link {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 18px;
        border-radius: 10px;
        background: #0A0F1E;
        border: 1px solid #1A2540;
        text-decoration: none;
        transition: border-color 0.2s, background 0.2s;
      }
      .connect-link:hover {
        background: #0C1220;
        border-color: #2A3A56;
      }
      .nav-back {
        font-size: 11px;
        color: #4A5A72;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        text-decoration: none;
        transition: color 0.2s;
      }
      .nav-back:hover { color: #F0F4FF; }
    </style>
  </head>
  <body>

    <!-- Nav -->
    <nav style="padding: 0 32px; height: 56px; border-bottom: 1px solid #0F1829; background: rgba(5,8,16,0.97); display: flex; align-items: center; justify-content: space-between; gap: 16px; position: sticky; top: 0; z-index: 50;">
      <!-- Logo left: flex:1 + min-width:0 prevents overflow into the back link -->
      <a href={import.meta.env.BASE_URL} style="display: flex; align-items: center; gap: 10px; text-decoration: none; flex: 1; min-width: 0;">
        <!-- Data Signal logo mark: oscilloscope waveform, not a lightning bolt -->
        <svg width="38" height="38" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0;">
          <rect width="30" height="30" rx="8" fill="#070D1C"/>
          <rect width="30" height="30" rx="8" fill="url(#ag)"/>
          <rect x="0.5" y="0.5" width="29" height="29" rx="7.5" stroke="#E25A1C" stroke-opacity="0.35" stroke-width="1" fill="none"/>
          <line x1="2" y1="15" x2="28" y2="15" stroke="#1A2A40" stroke-width="0.5"/>
          <polyline points="2,15 7,15 8.5,9 10,21 11.5,7 13,21 14.5,15 28,15" stroke="#E25A1C" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.15"/>
          <polyline points="2,15 7,15 8.5,9 10,21 11.5,7 13,21 14.5,15 28,15" stroke="#E25A1C" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <circle cx="28" cy="15" r="1.2" fill="#E25A1C" opacity="0.9"/>
          <defs>
            <linearGradient id="ag" x1="0" y1="0" x2="30" y2="30" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#0D1A30"/>
              <stop offset="100%" stop-color="#070D1C"/>
            </linearGradient>
          </defs>
        </svg>
        <div style="min-width: 0;">
          <div style="font-size: 17px; font-weight: 800; letter-spacing: 0.06em; color: #F0F4FF; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">DATA SIGNAL</div>
          <div style="font-size: 8px; color: #2E3E56; letter-spacing: 0.12em; text-transform: uppercase; white-space: nowrap;">Field Signals from Production</div>
        </div>
      </a>
      <a href={import.meta.env.BASE_URL} class="nav-back" style="flex-shrink: 0; white-space: nowrap;">← All Signals</a>
    </nav>

    <!-- Main content -->
    <div style="max-width: 740px; margin: 0 auto; padding: 64px 40px 100px;">

      <!-- Breadcrumb -->
      <div style="display: inline-flex; align-items: center; gap: 8px; padding: 4px 12px; border-radius: 20px; background: #0A0F1E; border: 1px solid #1A2540; margin-bottom: 40px;">
        <div style="width: 5px; height: 5px; border-radius: 50%; background: #E25A1C; box-shadow: 0 0 8px #E25A1C;"></div>
        <span style="font-size: 9px; color: #4A5A72; letter-spacing: 0.14em;">ABOUT THE AUTHOR</span>
      </div>

      <!-- Hero: avatar + name -->
      <div style="display: flex; align-items: flex-start; gap: 28px; margin-bottom: 36px;">
        <!-- Avatar -->
        <div style="position: relative; flex-shrink: 0;">
          <img
            src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/vara-linkedin.jpeg`}
            alt="Vara Bonthu"
            style="width: 88px; height: 88px; border-radius: 50%; object-fit: cover; object-position: center top; border: 2px solid #E25A1C40; box-shadow: 0 0 48px #E25A1C18;"
          />
          <!-- Online indicator -->
          <div style="position: absolute; bottom: 4px; right: 4px; width: 14px; height: 14px; border-radius: 50%; background: #22C55E; border: 2px solid #050810; box-shadow: 0 0 8px #22C55E80;"></div>
        </div>

        <!-- Name + title -->
        <div style="padding-top: 4px;">
          <h1 style="font-size: 36px; font-weight: 900; letter-spacing: -0.04em; color: #F0F4FF; line-height: 1; margin-bottom: 10px;">
            Vara Bonthu
          </h1>
          <div style="font-size: 14px; color: #E25A1C; font-weight: 700; letter-spacing: 0.02em; margin-bottom: 6px;">
            Data and AI on Kubernetes
          </div>
          <div style="font-size: 12px; color: #4A5A72; line-height: 1.5;">
            Principal Open Source Solutions Architect · AWS
          </div>
        </div>
      </div>

      <!-- Tag chips -->
      <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 40px;">
        {["Apache Spark", "Apache Flink", "Trino", "StarRocks", "Kubernetes", "EKS", "Karpenter", "Generative AI", "Open-Source Data"].map(tag => (
          <span style={`padding: 4px 12px; border-radius: 20px; background: #0A0F1E; border: 1px solid #1A2540; font-size: 10px; color: #5A6A7E; letter-spacing: 0.06em;`}>
            {tag}
          </span>
        ))}
      </div>

      <!-- Bio -->
      <div style="margin-bottom: 56px; padding: 28px 32px; border-radius: 16px; background: linear-gradient(160deg, #0A0F1E 0%, #080B18 100%); border: 1px solid #1A2540; border-left: 3px solid #E25A1C50; position: relative; overflow: hidden;">
        <div style="position: absolute; top: -40px; right: -40px; width: 160px; height: 160px; border-radius: 50%; background: radial-gradient(circle, #E25A1C08 0%, transparent 70%); pointer-events: none;"></div>
        <p style="font-size: 14px; color: #8A9CB0; line-height: 1.95; margin-bottom: 16px;">
          I'm the person companies call when their data platform is on fire — or when they want to make sure it never is.
          Over a decade working on large-scale data infrastructure across finance, retail, and technology,
          I've run into every flavor of Spark OOM, Flink checkpoint storm, and Trino memory cascade you can imagine.
        </p>
        <p style="font-size: 14px; color: #8A9CB0; line-height: 1.95; margin-bottom: 16px;">
          At AWS I work with some of the biggest data engineering teams in the world — helping them design, migrate,
          and operate open-source data frameworks natively on Kubernetes and EKS. My focus is the gap between
          what the framework documentation says and what production actually demands.
        </p>
        <p style="font-size: 14px; color: #8A9CB0; line-height: 1.95;">
          <strong style="color: #C0C8D8;">Data Signal is that gap, documented.</strong> Real learnings from real incidents,
          real cost reviews, and real architecture decisions. If a signal is on this site, it's because I've either
          fixed that problem myself or sat in the war room while someone else fixed it.
        </p>
      </div>

      <!-- Expertise grid -->
      <div style="margin-bottom: 56px;">
        <div style="font-size: 9px; color: #2E3E56; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 20px;">Areas of depth</div>
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;">
          {expertise.map(({ title, desc, color }) => (
            <div class="expertise-card">
              <div style={`font-size: 12px; font-weight: 700; color: ${color}; margin-bottom: 7px; letter-spacing: 0.02em;`}>
                {title}
              </div>
              <div style="font-size: 11px; color: #4A5A72; line-height: 1.65;">
                {desc}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Connect -->
      <div style="margin-bottom: 48px;">
        <div style="font-size: 9px; color: #2E3E56; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 20px;">Connect</div>
        <div style="display: flex; flex-direction: column; gap: 10px;">
          {connect.map(({ href, label, handle, color, svgPath }) => (
            <a href={href} target="_blank" rel="noopener noreferrer" class="connect-link">
              <div style={`color: ${color}; display: flex; align-items: center;`}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d={svgPath} />
                </svg>
              </div>
              <div style="flex: 1;">
                <div style="font-size: 12px; font-weight: 700; color: #D0D8E8;">{label}</div>
                <div style="font-size: 11px; color: #3A4A5E; margin-top: 2px;">{handle}</div>
              </div>
              <div style="font-size: 14px; color: #2E3E56;">→</div>
            </a>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div style="padding: 28px 32px; border-radius: 16px; background: linear-gradient(135deg, #0E1828 0%, #080B14 100%); border: 1px solid #E25A1C25; box-shadow: 0 0 60px #E25A1C08; display: flex; align-items: center; justify-content: space-between; gap: 20px;">
        <div>
          <div style="font-size: 15px; font-weight: 700; color: #F0F4FF; margin-bottom: 6px;">Read the Signals</div>
          <div style="font-size: 12px; color: #4A5A72; line-height: 1.6;">Production learnings from Spark, Flink, Trino &amp; StarRocks on Kubernetes</div>
        </div>
        <a href={import.meta.env.BASE_URL} style="padding: 10px 22px; border-radius: 10px; background: #E25A1C; color: #FFF; font-size: 13px; font-weight: 700; letter-spacing: 0.04em; text-decoration: none; white-space: nowrap; font-family: 'Space Grotesk', sans-serif;">
          View Signals →
        </a>
      </div>

    </div>
  </body>
</html>

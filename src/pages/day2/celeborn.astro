---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Apache Celeborn on Kubernetes — Production Guide · Data Signal</title>
<meta name="description" content="Field guide for deploying, scaling, and operating Apache Celeborn as a Remote Shuffle Service on Amazon EKS.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400&family=IBM+Plex+Mono:wght@300;400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d1117; --bg2: #161b22; --bg3: #1c2128; --bg4: #21262d;
    --border: #30363d; --border2: #3d444d;
    --text: #e6edf3; --text2: #8b949e; --text3: #6e7681;
    --accent: #f0883e; --accent2: #ffa657;
    --blue: #58a6ff; --green: #3fb950; --red: #f85149;
    --yellow: #d29922; --purple: #bc8cff; --teal: #39d0d8;
    --mono: 'IBM Plex Mono', monospace;
    --sans: 'IBM Plex Sans', sans-serif;
    --sitenav: 56px;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { background: var(--bg); color: var(--text); font-family: var(--sans); font-size: 15px; line-height: 1.7; }

  /* ── SITE NAV ── */
  .site-nav {
    position: fixed; left: 0; right: 0; top: 0; height: var(--sitenav);
    background: rgba(5,8,16,0.97); border-bottom: 1px solid #0F1829;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 24px; z-index: 200; backdrop-filter: blur(12px);
  }
  .site-nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
  .site-nav-back {
    font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #4A5A72;
    letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none;
    transition: color 0.2s; white-space: nowrap;
  }
  .site-nav-back:hover { color: #F0F4FF; }

  /* ── SIDEBAR ── */
  .sidebar {
    position: fixed; left: 0; top: var(--sitenav); bottom: 0;
    width: 260px; background: var(--bg2); border-right: 1px solid var(--border);
    overflow-y: auto; z-index: 100; padding: 0 0 40px 0;
  }
  .sidebar-logo { padding: 20px 20px 16px; border-bottom: 1px solid var(--border); margin-bottom: 8px; }
  .sidebar-logo .logo-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: linear-gradient(135deg, #f0883e22, #ffa65711);
    border: 1px solid var(--accent); border-radius: 6px; padding: 6px 10px; margin-bottom: 10px;
  }
  .sidebar-logo .logo-badge span { font-family: var(--mono); font-size: 11px; color: var(--accent); font-weight: 600; letter-spacing: 0.05em; }
  .sidebar-logo h1 { font-size: 14px; font-weight: 600; color: var(--text); line-height: 1.4; }
  .sidebar-logo p { font-size: 11px; color: var(--text3); font-family: var(--mono); margin-top: 4px; }
  .nav-section { padding: 8px 0; }
  .nav-section-title { font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text3); padding: 6px 20px 4px; }
  .nav-link {
    display: flex; align-items: center; gap: 8px; padding: 6px 20px;
    font-size: 13px; color: var(--text2); text-decoration: none;
    border-left: 2px solid transparent; transition: all 0.15s;
  }
  .nav-link:hover { color: var(--text); background: var(--bg3); border-left-color: var(--accent); }
  .nav-link.active { color: var(--accent); border-left-color: var(--accent); background: #f0883e0d; }
  .nav-link .dot { width: 5px; height: 5px; border-radius: 50%; background: var(--border2); flex-shrink: 0; }

  /* ── MAIN ── */
  .main { margin-left: 260px; min-height: 100vh; padding-top: var(--sitenav); }

  /* ── HERO ── */
  .hero { background: var(--bg2); border-bottom: 1px solid var(--border); padding: 64px 60px 48px; position: relative; overflow: hidden; }
  .hero::before { content: ''; position: absolute; top: -80px; right: -80px; width: 400px; height: 400px; background: radial-gradient(circle, #f0883e18 0%, transparent 70%); pointer-events: none; }
  .hero::after { content: ''; position: absolute; bottom: -60px; left: 200px; width: 300px; height: 300px; background: radial-gradient(circle, #58a6ff0d 0%, transparent 70%); pointer-events: none; }
  .hero-eyebrow { font-family: var(--mono); font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 16px; }
  .hero h2 { font-size: 36px; font-weight: 700; line-height: 1.2; color: var(--text); margin-bottom: 16px; letter-spacing: -0.02em; }
  .hero h2 span { color: var(--accent); }
  .hero-desc { font-size: 16px; color: var(--text2); max-width: 640px; line-height: 1.7; margin-bottom: 28px; }
  .hero-tags { display: flex; gap: 8px; flex-wrap: wrap; }
  .tag { font-family: var(--mono); font-size: 11px; padding: 3px 10px; border-radius: 20px; border: 1px solid; }
  .tag-orange { color: var(--accent); border-color: #f0883e44; background: #f0883e0d; }
  .tag-blue   { color: var(--blue);   border-color: #58a6ff44; background: #58a6ff0d; }
  .tag-green  { color: var(--green);  border-color: #3fb95044; background: #3fb9500d; }
  .tag-purple { color: var(--purple); border-color: #bc8cff44; background: #bc8cff0d; }
  .tag-teal   { color: var(--teal);   border-color: #39d0d844; background: #39d0d80d; }

  /* ── CONTENT ── */
  .content { padding: 48px 60px; max-width: 900px; }
  .section { margin-bottom: 64px; }
  .section-header { display: flex; align-items: center; gap: 12px; margin-bottom: 28px; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
  .section-number { font-family: var(--mono); font-size: 11px; color: var(--accent); background: #f0883e11; border: 1px solid #f0883e33; border-radius: 4px; padding: 2px 8px; flex-shrink: 0; }
  .section-header h2 { font-size: 22px; font-weight: 600; color: var(--text); letter-spacing: -0.01em; }
  p { color: var(--text2); margin-bottom: 16px; }
  strong { color: var(--text); font-weight: 600; }

  /* ── ARCH DIAGRAM ── */
  .arch-diagram { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 32px; margin: 24px 0; }
  .arch-row { display: flex; gap: 12px; margin-bottom: 12px; align-items: stretch; }
  .arch-arrow { display: flex; align-items: center; justify-content: center; color: var(--text3); font-size: 18px; padding: 0 4px; }
  .arch-box { flex: 1; border-radius: 8px; padding: 16px; border: 1px solid; text-align: center; }
  .arch-box .box-title { font-family: var(--mono); font-size: 12px; font-weight: 600; letter-spacing: 0.05em; margin-bottom: 4px; }
  .arch-box .box-desc { font-size: 11px; color: var(--text3); line-height: 1.5; }
  .arch-box-orange { background: #f0883e0d; border-color: #f0883e33; } .arch-box-orange .box-title { color: var(--accent); }
  .arch-box-blue   { background: #58a6ff0d; border-color: #58a6ff33; } .arch-box-blue   .box-title { color: var(--blue); }
  .arch-box-green  { background: #3fb9500d; border-color: #3fb95033; } .arch-box-green  .box-title { color: var(--green); }
  .arch-box-purple { background: #bc8cff0d; border-color: #bc8cff33; } .arch-box-purple .box-title { color: var(--purple); }
  .arch-box-teal   { background: #39d0d80d; border-color: #39d0d833; } .arch-box-teal   .box-title { color: var(--teal); }
  .arch-box-dim    { background: var(--bg3); border-color: var(--border); } .arch-box-dim .box-title { color: var(--text2); }
  .arch-label { font-family: var(--mono); font-size: 10px; color: var(--text3); text-align: center; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px; }

  /* ── CALLOUT ── */
  .callout { border-radius: 8px; padding: 16px 20px; margin: 20px 0; border-left: 3px solid; display: flex; gap: 12px; align-items: flex-start; }
  .callout-icon { font-size: 16px; flex-shrink: 0; margin-top: 2px; }
  .callout-body { flex: 1; }
  .callout-body strong { display: block; font-size: 13px; margin-bottom: 4px; }
  .callout-body p { font-size: 13px; margin-bottom: 0; }
  .callout-warning { background: #d2992215; border-color: var(--yellow); } .callout-warning strong { color: var(--yellow); }
  .callout-info    { background: #58a6ff0d; border-color: var(--blue); }  .callout-info strong { color: var(--blue); }
  .callout-success { background: #3fb9500d; border-color: var(--green); } .callout-success strong { color: var(--green); }
  .callout-danger  { background: #f8514915; border-color: var(--red); }   .callout-danger strong { color: var(--red); }

  /* ── CODE ── */
  .code-block { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; margin: 16px 0; overflow: hidden; }
  .code-header { display: flex; align-items: center; justify-content: space-between; padding: 8px 16px; background: var(--bg4); border-bottom: 1px solid var(--border); }
  .code-lang { font-family: var(--mono); font-size: 11px; color: var(--accent); font-weight: 500; }
  .code-file { font-family: var(--mono); font-size: 11px; color: var(--text3); }
  pre { padding: 20px; overflow-x: auto; font-family: var(--mono); font-size: 12.5px; line-height: 1.7; color: var(--text2); }
  .kw  { color: var(--purple); } .str { color: var(--green); } .num { color: var(--accent2); }
  .cmt { color: var(--text3); font-style: italic; } .key { color: var(--blue); } .val { color: var(--teal); }

  /* ── TABLE ── */
  .table-wrap { overflow-x: auto; margin: 20px 0; border-radius: 8px; border: 1px solid var(--border); }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  thead { background: var(--bg3); }
  th { font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text3); padding: 10px 16px; text-align: left; border-bottom: 1px solid var(--border); white-space: nowrap; }
  td { padding: 10px 16px; border-bottom: 1px solid var(--border); color: var(--text2); vertical-align: top; }
  td:first-child { font-family: var(--mono); font-size: 12px; color: var(--blue); }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--bg3); }
  .td-default { color: var(--accent2); font-family: var(--mono); font-size: 12px; }
  .td-recommended { color: var(--teal); font-family: var(--mono); font-size: 12px; }

  /* ── GRID CARDS ── */
  .card-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin: 20px 0; }
  .card { background: var(--bg2); border: 1px solid var(--border); border-radius: 8px; padding: 20px; transition: border-color 0.15s; }
  .card:hover { border-color: var(--border2); }
  .card-icon { font-size: 20px; margin-bottom: 10px; }
  .card h4 { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 8px; }
  .card p { font-size: 13px; color: var(--text3); margin: 0; line-height: 1.6; }

  /* ── STEPS ── */
  .steps { margin: 20px 0; position: relative; }
  .step { display: flex; gap: 20px; margin-bottom: 24px; }
  .step-num { width: 28px; height: 28px; border-radius: 50%; background: #f0883e22; border: 1px solid var(--accent); color: var(--accent); font-family: var(--mono); font-size: 12px; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; }
  .step-body h4 { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 6px; }
  .step-body p { font-size: 13px; margin-bottom: 0; }

  /* ── INLINE CODE ── */
  code { font-family: var(--mono); font-size: 12px; background: var(--bg4); border: 1px solid var(--border); border-radius: 4px; padding: 1px 6px; color: var(--teal); }

  /* ── COMPARISON ── */
  .compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 20px 0; }
  .compare-card { border-radius: 8px; padding: 20px; border: 1px solid; }
  .compare-card h4 { font-size: 13px; font-weight: 600; margin-bottom: 12px; font-family: var(--mono); letter-spacing: 0.05em; }
  .compare-card ul { list-style: none; padding: 0; }
  .compare-card ul li { font-size: 12.5px; color: var(--text2); padding: 4px 0 4px 16px; position: relative; border-bottom: 1px solid var(--border); line-height: 1.5; }
  .compare-card ul li:last-child { border-bottom: none; }
  .compare-card ul li::before { content: ''; position: absolute; left: 0; top: 11px; width: 6px; height: 6px; border-radius: 50%; }
  .compare-pro { background: #3fb9500d; border-color: #3fb95033; } .compare-pro h4 { color: var(--green); } .compare-pro ul li::before { background: var(--green); }
  .compare-con { background: #f8514910; border-color: #f8514933; } .compare-con h4 { color: var(--red); }   .compare-con ul li::before { background: var(--red); }

  /* ── LIFECYCLE ── */
  .lifecycle { display: flex; gap: 0; margin: 20px 0; overflow-x: auto; }
  .lifecycle-step { flex: 1; min-width: 120px; padding: 14px 12px; text-align: center; background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); border-right: 1px solid var(--border); position: relative; }
  .lifecycle-step:first-child { border-left: 1px solid var(--border); border-radius: 8px 0 0 8px; }
  .lifecycle-step:last-child { border-radius: 0 8px 8px 0; }
  .lifecycle-step.active { background: #f0883e0d; border-color: #f0883e44; }
  .lifecycle-step .ls-num { font-family: var(--mono); font-size: 10px; color: var(--text3); margin-bottom: 6px; }
  .lifecycle-step .ls-title { font-size: 11px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
  .lifecycle-step .ls-desc { font-size: 10px; color: var(--text3); line-height: 1.5; }
  .lifecycle-step.active .ls-title { color: var(--accent); }

  /* ── BENCHMARK BAR ── */
  .bench-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
  .bench-label { font-family: var(--mono); font-size: 11px; color: var(--text2); width: 120px; flex-shrink: 0; text-align: right; }
  .bench-bar-wrap { flex: 1; background: var(--bg3); border-radius: 4px; height: 20px; overflow: hidden; }
  .bench-bar { height: 100%; border-radius: 4px; display: flex; align-items: center; padding-left: 8px; font-family: var(--mono); font-size: 10px; font-weight: 600; }
  .bench-bar-green  { background: linear-gradient(90deg, #3fb95044, #3fb950); color: #3fb950; }
  .bench-bar-orange { background: linear-gradient(90deg, #f0883e44, #f0883e); color: #f0883e; }
  .bench-bar-red    { background: linear-gradient(90deg, #f8514944, #f85149); color: #f85149; }
  .bench-bar-blue   { background: linear-gradient(90deg, #58a6ff44, #58a6ff); color: #58a6ff; }

  /* ── FOOTER ── */
  .doc-footer { border-top: 1px solid var(--border); padding: 32px 60px; display: flex; justify-content: space-between; align-items: center; }
  .doc-footer p { font-family: var(--mono); font-size: 11px; color: var(--text3); margin: 0; }
  .doc-footer a { color: var(--blue); text-decoration: none; }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg2); }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--text3); }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .sidebar { display: none; }
    .main { margin-left: 0; }
    .hero, .content { padding: 32px 24px; }
    .card-grid, .compare-grid { grid-template-columns: 1fr; }
    .doc-footer { flex-direction: column; gap: 8px; padding: 24px; }
  }
</style>
</head>
<body>

<!-- ── SITE NAV ── -->
<nav class="site-nav">
  <a href={`${base}/`} class="site-nav-logo">
    <svg width="30" height="30" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="30" height="30" rx="8" fill="#070D1C"/>
      <rect width="30" height="30" rx="8" fill="url(#cg)"/>
